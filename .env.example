# ── HuggingFace ───────────────────────────────────────────────
# Get your token from: huggingface.co → Settings → Access Tokens
# Required to download Llama 3.2 3B (Meta license gated)
HF_TOKEN=your_huggingface_token_here

# ── OpenAI (for GPT-4o evaluation judge) ──────────────────────
# Only needed in notebook 04_evaluation.ipynb
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Kaggle (optional local use) ───────────────────────────────
# Not needed if running directly on Kaggle notebooks
# Only needed if calling Kaggle API from your Mac
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ─────────────────────────────────────────────────────────────
# IMPORTANT: Copy this file to .env and fill in real values
#            NEVER commit .env to git — it is in .gitignore
# cp .env.example .env
# ─────────────────────────────────────────────────────────────
